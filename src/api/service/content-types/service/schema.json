{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service",
    "description": "Service pages for legal, banking, insurance and relocation support."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "shortLabel": {
      "type": "string"
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "body": {
      "type": "richtext"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "real-estate",
        "legal",
        "finance",
        "insurance",
        "relocation",
        "documents"
      ]
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
